# ============================================
# Mirage Configuration
# ============================================

# --- Server ---
SERVER_PORT=8443
SERVER_HOST=0.0.0.0

# --- Database ---
DATABASE_URL=postgres://mirage:mirage@localhost:5432/miragedb?sslmode=disable

# --- Docker ---
# Windows: npipe:////./pipe/docker_engine
# Linux/Mac: unix:///var/run/docker.sock
DOCKER_HOST=npipe:////./pipe/docker_engine
SANDBOX_IMAGE=mirage-tools:latest

# --- LLM Authentication ---
# PREFERRED: Codex CLI OAuth (no API key needed!)
# 1. Install: npm install -g @openai/codex
# 2. Login:   codex login  (authenticates with your ChatGPT account)
# 3. Done!    Mirage will read the cached token from ~/.codex/auth.json
#
# OPTIONAL: Override the default Codex config directory
# CODEX_HOME=~/.codex
#
# FALLBACK: Set an API key if you prefer not to use Codex OAuth
# OPENAI_API_KEY=sk-your-openai-api-key

# --- LLM Model Settings ---
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1

# --- Search (Optional) ---
TAVILY_API_KEY=
SHODAN_API_KEY=

# --- Frontend ---
VITE_API_URL=localhost:8443
VITE_WS_URL=ws://localhost:8443/ws
VITE_PORT=3000
