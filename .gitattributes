# Enforce consistent encoding and line endings across all platforms.
# Prevents mojibake from UTF-8 / Windows-1252 misinterpretation.

# Source code: always UTF-8 with LF line endings
*.go        text eol=lf working-tree-encoding=UTF-8
*.js        text eol=lf working-tree-encoding=UTF-8
*.jsx       text eol=lf working-tree-encoding=UTF-8
*.ts        text eol=lf working-tree-encoding=UTF-8
*.tsx       text eol=lf working-tree-encoding=UTF-8
*.css       text eol=lf working-tree-encoding=UTF-8
*.html      text eol=lf working-tree-encoding=UTF-8
*.json      text eol=lf working-tree-encoding=UTF-8
*.yaml      text eol=lf working-tree-encoding=UTF-8
*.yml       text eol=lf working-tree-encoding=UTF-8
*.md        text eol=lf working-tree-encoding=UTF-8
*.sql       text eol=lf working-tree-encoding=UTF-8
*.sh        text eol=lf working-tree-encoding=UTF-8
*.py        text eol=lf working-tree-encoding=UTF-8

# Config files
*.env*      text eol=lf working-tree-encoding=UTF-8
Dockerfile  text eol=lf working-tree-encoding=UTF-8
Makefile    text eol=lf working-tree-encoding=UTF-8
*.toml      text eol=lf working-tree-encoding=UTF-8
*.mod       text eol=lf working-tree-encoding=UTF-8
*.sum       text eol=lf working-tree-encoding=UTF-8

# Binary files: do not modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
